{
  "extends": "expo/tsconfig.base",      
  "compilerOptions": {
    "strict": true,                     
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },
    "jsx": "react-native",
    "types": ["jest", "react-native"]
  },
  // Folders (globs) TypeScript should include / exclude
  "include": ["app", "src", "tests"],  
  "exclude": ["node_modules", "android", "ios", ".expo"]
}